OTP_PROVIDER=mock
# Local UAT: use Twilio Sandbox as transport while treating 069 583 1160 as the mocked WABA/RICA line.
# Production: set WHATSAPP_TRANSPORT_MODE=production and use live Twilio/Meta WABA credentials.
WHATSAPP_TRANSPORT_MODE=sandbox
TWILIO_SANDBOX_WHATSAPP_NUMBER=whatsapp:+14155238886
MOCK_WABA_NUMBER=whatsapp:+27695831160

# Twilio WhatsApp BSP — inbound + outbound messaging
# Account SID and Auth Token from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The registered WhatsApp sender number in E.164 format (prefix whatsapp: is accepted too)
TWILIO_WHATSAPP_NUMBER=+27695831160
BIOMETRIC_PROVIDER=mock
WHAT3WORDS_API_KEY=
# Use "supabase" for database persistence or "memory" for offline local UAT.
KYC_PERSISTENCE=supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
# Server-side only. Required when Supabase Row Level Security is enabled.
SUPABASE_SERVICE_ROLE_KEY=
WHATSAPP_SESSION_SECRET=
REDIS_URL=redis://localhost:6379
BULLMQ_QUEUE_PREFIX=kyc-now
BULLMQ_WORKER_CONCURRENCY=5
INTERNAL_API_BASE_URL=http://localhost:3000
